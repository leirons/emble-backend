# --- Server ---
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
DASHBOARD_ORIGIN=http://localhost:3000

# --- Postgres ---
DATABASE_URL=postgres://emble:emble@localhost:5432/emble

# --- Redis (rate-limit, cache; в BullMQ-режиме — ещё и очередь) ---
REDIS_URL=redis://localhost:6379

# --- Фоновая очередь ---
# Задайте QSTASH_TOKEN (Upstash QStash) для serverless-режима: задачи ставятся в QStash,
# он вызывает /internal/jobs/* — отдельный worker.js не нужен (для Vercel и др.).
# Оставьте пустым для локальной разработки — тогда работает BullMQ + `npm run worker`.
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io
# Общий секрет для внутренних job-эндпоинтов (любая длинная случайная строка).
JOB_SECRET=

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- S3 / R2 (файлы базы знаний, аватары) ---
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=emble-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://cdn.emble.ai/uploads

# --- LLM providers ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
DEFAULT_LLM_PROVIDER=openai

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# --- Widget ---
WIDGET_CDN_BASE_URL=https://cdn.emble.ai
